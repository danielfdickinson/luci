{
	"luci-app-nut": {
		"description": "Grant UCI access for luci-app-nut",
		"read": {
			"file": {
				"/etc/ssl/certs": [ "list" ],
				"/lib/nut/": [ "list" ],
				"/usr/libexec/nut/": [ "list" ],
				"/usr/bin/ldd /usr/sbin/upsmon": ["exec"],
				"/usr/bin/ldd /usr/sbin/upsd": ["exec"]
			},
			"uci": [ "nut_cgi", "nut_monitor", "nut_server" ]
		},
		"write": {
			"uci": [ "nut_cgi", "nut_monitor", "nut_server" ],
			"file": {
				"/etc/luci-uploads/*": ["write"]
			}
		}
	}
}
